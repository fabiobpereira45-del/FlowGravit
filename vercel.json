{
    "version": 2,
    "builds": [
        {
            "src": "api/server.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}